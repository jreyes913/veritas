{
  "name": "Veritas",
  "scopeName": "source.veritas",
  "fileTypes": ["ver"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#identifier" },
    { "include": "#number" },
    { "include": "#keyword_red" },
    { "include": "#keyword_orange" },
    { "include": "#keyword_blue" },
    { "include": "#keyword_green" },
    { "include": "#keyword_purple" },
    { "include": "#keyword_yellow" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.veritas",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.veritas" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.veritas" } }
    },
    "string": {
      "name": "string.quoted.double.veritas",
      "begin": "\"",
      "end": "\"",
      "patterns": [ { "name": "constant.character.escape.veritas", "match": "\\\\[nrtf\\\\\"']" } ]
    },
    "identifier": {
      "name": "variable.other.veritas",
      "match": "'[A-Za-z_][A-Za-z0-9_]*'"
    },
    "number": {
      "name": "constant.numeric.veritas",
      "match": "-?\\b[0-9]+(?:\\.[0-9]+)?j?\\b"
    },
    "keyword_red": {
      "patterns": [
        { "name": "veritas.kw.red", "match": "\\b(This is the program|End of the program|If|Otherwise|End if|For every iteration|End iteration|End function|Define dimension|Define unit)\\b" }
      ]
    },
    "keyword_orange": {
      "patterns": [
        { "name": "veritas.kw.orange", "match": "\\b(Include the|Include|Define the function|Create)\\b" }
      ]
    },
    "keyword_blue": {
      "patterns": [
        { "name": "veritas.kw.blue", "match": "\\b(Call|Replace|Load|Save|Export|stored to|returning|for report)\\b" }
      ]
    },
    "keyword_green": {
      "patterns": [
        { "name": "veritas.kw.green", "match": "\\b(as|an|a|for)\\b" },
        { "name": "storage.type.veritas", "match": "\\b(nothing|string|int|float|double|complex|vector|matrix|pointer|unsigned|uint\\d+_t|int\\d+_t)\\b" }
      ]
    },
    "keyword_purple": {
      "patterns": [
        { "name": "veritas.kw.purple", "match": "\\b(the quantity)\\b" }
      ]
    },
    "keyword_yellow": {
      "patterns": [
        { "name": "veritas.kw.yellow", "match": "\\b(plus|minus|multiplied by|divided by|is equal to|is greater than|is less than|and|with|with value|with values|at index|an element of|the address of|value at|array of size|of|from|through|to|symbol|squared|cubed)\\b" }
      ]
    },
    "punctuation": {
      "name": "punctuation.terminator.veritas",
      "match": "(?<!\\d)\\.(?!\\d)|:|,|;|\\<|\\>"
    }
  }
}
