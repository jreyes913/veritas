{
  "name": "Veritas",
  "scopeName": "source.veritas",
  "fileTypes": ["ver"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#identifier" },
    { "include": "#number" },
    { "include": "#starterProgram" },
    { "include": "#starterInclude" },
    { "include": "#starterFunction" },
    { "include": "#starterDeclaration" },
    { "include": "#starterAssignment" },
    { "include": "#starterCall" },
    { "include": "#starterIteration" },
    { "include": "#starterConditional" },
    { "include": "#typeContext" },
    { "include": "#operator" },
    { "include": "#otherKeyword" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.veritas",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.veritas" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.veritas" } }
    },
    "string": {
      "name": "string.quoted.double.veritas",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.veritas",
          "match": "\\\\[nrtf\\\\\"']"
        }
      ]
    },
    "identifier": {
      "name": "variable.other.veritas",
      "match": "'[A-Za-z_][A-Za-z0-9_]*'"
    },
    "number": {
      "name": "constant.numeric.veritas",
      "match": "-?\\b[0-9]+(?:\\.[0-9]+)?j?\\b"
    },
    "starterProgram": {
      "patterns": [
        {
          "name": "keyword.control.program.start.veritas",
          "match": "\\bThis\\s+is\\s+the\\s+program\\b"
        },
        {
          "name": "keyword.control.program.end.veritas",
          "match": "\\bEnd\\s+of\\s+the\\s+program\\b"
        }
      ]
    },
    "starterInclude": {
      "name": "keyword.control.include.veritas",
      "match": "\\bInclude\\s+the\\b"
    },
    "starterFunction": {
      "patterns": [
        {
          "name": "keyword.control.function.start.veritas",
          "match": "\\bDefine\\s+the\\s+function\\b"
        },
        {
          "name": "keyword.control.function.end.veritas",
          "match": "\\bEnd\\s+function\\b"
        }
      ]
    },
    "starterDeclaration": {
      "name": "keyword.control.declaration.veritas",
      "match": "\\bCreate\\b"
    },
    "starterAssignment": {
      "name": "keyword.control.assignment.veritas",
      "match": "\\bReplace\\b"
    },
    "starterCall": {
      "name": "keyword.control.call.veritas",
      "match": "\\bCall\\b"
    },
    "starterIteration": {
      "patterns": [
        {
          "name": "keyword.control.loop.start.veritas",
          "match": "\\bFor\\s+every\\s+iteration\\b"
        },
        {
          "name": "keyword.control.loop.end.veritas",
          "match": "\\bEnd\\s+iteration\\b"
        }
      ]
    },
    "starterConditional": {
      "patterns": [
        {
          "name": "keyword.control.conditional.end.veritas",
          "match": "\\bEnd\\s+if\\b"
        },
        {
          "name": "keyword.control.conditional.else.veritas",
          "match": "\\bOtherwise\\b"
        },
        {
          "name": "keyword.control.conditional.if.veritas",
          "match": "\\bIf\\b"
        }
      ]
    },
    "typeContext": {
      "patterns": [
        {
          "name": "storage.type.veritas",
          "match": "\\bnothing\\b"
        },
        {
          "begin": "\\b(as|returning)\\s+",
          "beginCaptures": {
            "1": { "name": "keyword.other.veritas" }
          },
          "end": "(?=\\b(with\\s+value|with\\s+values|with|from|through|to|stored\\s+to|and)\\b|[:.,]|$)",
          "patterns": [
            {
              "name": "keyword.other.veritas",
              "match": "\\ban?\\b"
            },
            {
              "name": "storage.type.veritas",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "operator": {
      "name": "keyword.operator.veritas",
      "match": "\\b(multiplied\\s+by|divided\\s+by|plus|minus|is\\s+greater\\s+than\\s+or\\s+equal\\s+to|is\\s+less\\s+than\\s+or\\s+equal\\s+to|is\\s+greater\\s+than|is\\s+less\\s+than|is\\s+equal\\s+to)\\b"
    },
    "otherKeyword": {
      "name": "keyword.other.veritas",
      "match": "\\b(library|header|function|program|iteration|of|from|through|to|with|with\\s+value|with\\s+values|stored\\s+to|the\\s+address\\s+of|value\\s+at|an\\s+element\\s+of|at\\s+index|array\\s+of\\s+size|the\\s+quantity|and)\\b"
    },
    "punctuation": {
      "name": "punctuation.terminator.veritas",
      "match": "(?<!\\d)\\.(?!\\d)|:|,|;"
    }
  }
}
