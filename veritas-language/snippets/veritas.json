{
  "Program Skeleton": {
    "prefix": "program",
    "body": [
      "This is the program '${1:name}'.",
      "",
      "${0}",
      "",
      "End of the program '${1:name}'."
    ],
    "description": "Create a new Veritas program"
  },
  "Include": {
    "prefix": "include",
    "body": [
      "Include '${1:units.ver}'."
    ],
    "description": "Include a Veritas file"
  },
  "Define Dimension": {
    "prefix": "dimension",
    "body": [
      "Define dimension '${1:Length}'."
    ],
    "description": "Define a physical dimension"
  },
  "Define Unit": {
    "prefix": "unit",
    "body": [
      "Define unit '${1:meter}' for '${2:Length}' with symbol \"${3:m}\"."
    ],
    "description": "Define a base unit"
  },
  "Export": {
    "prefix": "export",
    "body": [
      "Export '${1:var}' as '${2:Label}' for report."
    ],
    "description": "Export variable for reporting"
  },
  "Function Definition": {
    "prefix": "define",
    "body": [
      "Define the function '${1:funcName}'",
      "with '${2:param}' as a ${3:type}",
      "returning ${4:nothing}.",
      "",
      "    ${0}",
      "",
      "End function '${1:funcName}'."
    ],
    "description": "Define a new function"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "For every iteration of '${1:i}' from ${2:0} through ${3:N}:",
      "    ${0}",
      "End iteration of '${1:i}' from ${2:0} through ${3:N}."
    ],
    "description": "For loop iteration"
  },
  "If Else Block": {
    "prefix": "if",
    "body": [
      "If ${1:condition}:",
      "    ${2:/* then */}",
      "Otherwise:",
      "    ${3:/* else */}",
      "End if ${1:condition}."
    ],
    "description": "If/Else conditional block"
  },
  "Create Scalar": {
    "prefix": "create",
    "body": [
      "Create '${1:var}' as a ${2:double}${3:<unit>} with value ${4:0.0}."
    ],
    "description": "Create a scalar variable"
  },
  "Create Array": {
    "prefix": "array",
    "body": [
      "Create '${1:arr}' as a ${2:type} array of size ${3:5} with values:",
      "${4:1},",
      "and ${5:5}."
    ],
    "description": "Create an array with values"
  },
  "Create Vector": {
    "prefix": "vector",
    "body": [
      "Create '${1:v}' as a ${2:double} vector of size ${3:3} with values: ${4:1.0}, ${5:2.0}, and ${6:3.0}."
    ],
    "description": "Create a vector with values"
  }
}
