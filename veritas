# --- 3. Scan .ver source and collect flags ---------------------------------

declare -A seen_flags   # deduplicate
linker_flags=()

for header in "${!LIB_MAP[@]}"; do
    flag_str="${LIB_MAP[$header]}"
    [[ -z "$flag_str" ]] && continue

    if grep -qF "Include the library '${header}'" "$source_file" || \
       grep -qF "Include the header '${header}'" "$source_file"; then
        read -ra tokens <<< "$flag_str"
        for tok in "${tokens[@]}"; do
            if [[ -z "${seen_flags[$tok]+set}" ]]; then
                seen_flags[$tok]=1
                linker_flags+=("$tok")
            fi
        done
    fi
done

# --- 4. Compile ------------------------------------------------------------

echo "gcc linker flags: ${linker_flags[*]:-<none>}"
gcc -o "${output_base}" "${output_base}.c" "${SCRIPT_DIR}/compiler/runtime.c" "${linker_flags[@]+"${linker_flags[@]}"}" -lm

