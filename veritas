#!/bin/bash

# ---------------------------------------------------------------------------
# veritas — compile a .ver source file to a native binary
#
# Usage:  veritas <file.ver>
#
# Automatically detects included libraries from the .ver source and maps
# them to the correct gcc linker flags.
# ---------------------------------------------------------------------------

set -euo pipefail

# Resolve the absolute path of the directory where this script is located
SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)

if [[ $# -lt 1 ]]; then
    echo "Usage: veritas <source.ver> [--tokens|--ast|--ir|--semantics]" >&2
    exit 1
fi

source_file="$1"
shift

# Check if file exists
if [[ ! -f "$source_file" ]]; then
    echo "Error: File '$source_file' not found." >&2
    exit 1
fi

debug_flags=()
for arg in "$@"; do
    case "$arg" in
        --tokens|--ast|--ir|--semantics)
            debug_flags+=("$arg")
            ;;
        *)
            echo "Unknown flag: $arg" >&2
            exit 1
            ;;
    esac
done

# Resolve names and paths
filename=$(basename -- "$source_file" | sed 's/\.ver$//g')
output_dir=$(dirname -- "$(realpath "$source_file")")
output_base="${output_dir}/${filename}"

# --- 1. Transpile .ver → .c ------------------------------------------------
if [[ ${#debug_flags[@]} -gt 0 ]]; then
    python3 "${SCRIPT_DIR}/vcparser.py" "$source_file" "${debug_flags[@]}"
    exit 0
fi

python3 "${SCRIPT_DIR}/vcparser.py" "$source_file" > "${output_base}.c"

